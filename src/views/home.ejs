<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verdear | Sua Vitrine</title>
    <link rel="icon" type="logo/png" href="/logo_simplificada.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/home.css">
</head>

<body>
    <div class="main-box">
        <div id="cart-notification">
            Item adicionado ao carrinho!
        </div>

        <header class="main-header">
            <div class="header-left">
                <a href="/"><img src="/logo-sem-fundo.png" alt="Verdear Logo" class="logo"></a>
            </div>

            <form class="search-bar" action="/produtos/busca" method="GET" style="display:flex; align-items:center;">

                <button type="submit"
                    style="background: none; border: none; color: var(--color-white); cursor: pointer; padding: 0 10px;">
                    <i class="fas fa-search"></i>
                </button>
                <input type="text" name="q" placeholder="Pesquisar produtos..." style="flex: 1;">

            </form>

            <div class="header-icons">
                <div class="icon-btn"><i class="far fa-comment-dots"></i></div>
                <a href="/carrinho" class="icon-btn"><i class="fas fa-shopping-cart"></i></a>
                <a href="/gestao-cadastro" class="icon-btn user" style="text-decoration: none;"><i
                        class="far fa-user"></i></a>
            </div>
        </header>

        <section class="banner-container">
            <div class="carousel-inner" id="carousel-inner">
                <div class="banner-item">
                    <a href="" target="_blank" style="text-decoration: none; color: inherit;">
                        <img src="/banner1.png" alt="Banner 1" class="banner-img">
                        <div class="banner-overlay">
                        </div>
                    </a>
                </div>

                <div class="banner-item">
                    <a href="https://g1.globo.com/sp/presidente-prudente-e-regiao/noticia/2025/11/18/agricultura-familiar-e-organica-e-fonte-de-renda-para-familias-no-interior-de-sp.ghtml"
                        target="_blank" style="text-decoration: none; color: inherit;">
                        <img src="/banner2.png" alt="Banner 2" class="banner-img">
                        <div class="banner-overlay">
                        </div>
                    </a>
                </div>

                <div class="banner-item">
                    <a href="https://www.kuhnbrasil.com.br/noticias/agricultura-familiar-forca-que-alimenta-o-brasil"
                        target="_blank" style="text-decoration: none; color: inherit;">
                        <img src="/banner3.png" alt="Banner 3" class="banner-img">
                        <div class="banner-overlay">
                        </div>
                    </a>
                </div>
            </div>

            <button class="carousel-control prev" id="prev-btn" aria-label="Anterior">&#10094;</button>
            <button class="carousel-control next" id="next-btn" aria-label="Próximo">&#10095;</button>
        </section>

        <section class="categories-section">

            <% const categories=[ { id: 1, name: 'Hortifrúti' , iconUrl: '/icons/frutas.png' }, { id: 2,
                name: 'Laticínios' , iconUrl: '/icons/verduras.png' }, { id: 3, name: 'Grãos' ,
                iconUrl: '/icons/laticinios.png' }, { id: 4, name: 'Pães e Massas' , iconUrl: '/icons/graos.png' }, {
                id: 6, name: 'Temperos' , iconUrl: '/icons/especiarias.png' } ]; %>

                <% categories.forEach(category=> { %>
                    <a href="/itens_categoria/<%= category.id %>" class="category-item">
                        <div class="category-icon">
                            <i class="fas fa-tractor fa-2x" style="color:#528b3a;"></i>
                        </div>
                        <%= category.name %>
                    </a>
                    <% }); %>
        </section>

        <section class="products-section">
            <% if (produtos && produtos.length> 0) { %>
                <% produtos.forEach(produto=> { %>
                    <div class="product-card" data-product-id="<%= produto.id_produto %>">
                        <div class="rating">
                            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i
                                class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                        </div>

                        <div class="product-image-container">
                            <% if (produto.url_imagem) { %>
                                <img src="<%= produto.url_imagem %>" alt="<%= produto.nome_produto %>">
                                <% } else { %>
                                    <img src="https://via.placeholder.com/200x150/d9ead3/386641?text=<%= produto.nome_produto.split(' ')[0] %>"
                                        alt="<%= produto.nome_produto %>">
                                    <% } %>
                        </div>

                        <div style="padding: 10px 0; color: var(--color-white);">
                            <h4 style="margin: 5px 0; font-size: 1em;">
                                <%= produto.nome_produto %>
                            </h4>
                        </div>

                        <div class="product-details">
                            <span class="price">R$ <%= parseFloat(produto.preco).toFixed(2).replace('.', ',' ) %></span>
                            <div class="add-btn"><i class="fas fa-plus"></i></div>
                        </div>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <div style="width: 100%; text-align: center; padding: 40px; color: var(--color-text-dark);">
                                <p>Nenhum produto disponível no momento.</p>
                            </div>
                            <% } %>
        </section>
    </div>

    <script>
        // Lógica do Carrinho (Notificação)
        const productCards = document.querySelectorAll('.product-card');
        const notification = document.getElementById('cart-notification');

        productCards.forEach(card => {
            card.addEventListener('click', function () {
                const productId = this.getAttribute('data-product-id');

                fetch("/carrinho/add", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        id_produto: productId,
                        quantidade: 1
                    })
                })
                    .then(res => res.json())
                    .then((data) => {
                        if (data.success) {
                            notification.classList.add('show');
                            setTimeout(() => {
                                notification.classList.remove('show');
                            }, 2000);
                        } else {
                            alert(data.message || "Erro ao adicionar ao carrinho");
                        }
                    })
                    .catch(err => {
                        console.error("Erro:", err);
                        alert("Erro ao adicionar produto ao carrinho");
                    });
            });
        });

        // Lógica do Carousel
        const carouselInner = document.getElementById('carousel-inner');
        const carouselItems = document.querySelectorAll('.banner-item');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');

        let currentIndex = 0; // Índice da imagem atual
        const totalItems = carouselItems.length;

        function updateCarousel() {
            // Move o carousel (o container interno) para a esquerda em múltiplos de 100%
            carouselInner.style.transform = `translateX(-${currentIndex * 100}%)`;
        }

        // Event listener para a seta "Próximo"
        nextBtn.addEventListener('click', () => {
            // Avança, mas volta para 0 se passar do último
            currentIndex = (currentIndex + 1) % totalItems;
            updateCarousel();
        });

        // Event listener para a seta "Anterior"
        prevBtn.addEventListener('click', () => {
            // Volta, mas vai para o último se for menor que 0
            currentIndex = (currentIndex - 1 + totalItems) % totalItems;
            updateCarousel();
        });

    </script>
</body>

</html>