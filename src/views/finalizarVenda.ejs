<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verdear | Finalizar Venda</title>
    <link rel="icon" type="logo/png" href="/logo_simplificada.png"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/finalizar_venda.css">
</head>
<body>
<div class="main-box">
    <header class="main-header">
        <div class="header-left">
            <a href="/home"><img src="/logo-sem-fundo.png" alt="Verdear Logo" class="logo"></a>
        </div>

        
            <form class="search-bar" action="/produtos/busca" method="GET" style="display:flex; align-items:center;">

                <button type="submit"
                    style="background: none; border: none; color: var(--color-white); cursor: pointer; padding: 0 10px;">
                    <i class="fas fa-search"></i>
                </button>
                <input type="text" name="q" placeholder="Pesquisar produtos..." style="flex: 1;">

            </form>

        <div class="header-icons">
            <div class="icon-btn"><i class="far fa-comment-dots"></i></div>
            <a href="/carrinho" class="icon-btn"><i class="fas fa-shopping-cart"></i></a>
            <a href="/gestao-cadastro" class="icon-btn user"><i class="far fa-user"></i></a>
        </div>
    </header>

    <div class="checkout-container">
        
        <div class="checkout-section">
            <h2 class="section-title">Resumo do Pedido</h2>
            
            <% if (itens && itens.length > 0) { %>
                <% itens.forEach(item => { %>
                    <div class="item-list">
                        <div class="item-row">
                            <span><strong><%= item.nome %></strong></span>
                            <span>Qtd: <%= item.quantidade %></span>
                        </div>
                        <div class="item-row">
                            <span>Preço unitário: R$ <%= parseFloat(item.preco).toFixed(2).replace('.', ',') %></span>
                            <span><strong>Subtotal: R$ <%= (item.preco * item.quantidade).toFixed(2).replace('.', ',') %></strong></span>
                        </div>
                    </div>
                <% }); %>

                <div class="total-row">
                    <span>Subtotal:</span>
                    <span>R$ <%= subtotal.toFixed(2).replace('.', ',') %></span>
                </div>
                <div class="total-row">
                    <span>Frete:</span>
                    <span>R$ <%= custoFrete.toFixed(2).replace('.', ',') %></span>
                </div>
                <div class="total-row">
                    <span>TOTAL:</span>
                    <span>R$ <%= total.toFixed(2).replace('.', ',') %></span>
                </div>
            <% } else { %>
                <p>Nenhum item no carrinho.</p>
            <% } %>
        </div>

        <div class="checkout-section">
            <h2 class="section-title">Informações do Pedido</h2>
            <div class="info-box">
                <p><strong>Forma de Pagamento:</strong> <%= formaPagamento %></p>
                <p><strong>Tipo de Entrega:</strong> <%= tipoEntrega %></p>
                <% if (tipoEntrega === 'ENTREGA') { %>
                    <p><strong>Valor do Frete:</strong> R$ <%= custoFrete.toFixed(2).replace('.', ',') %></p>
                <% } %>
            </div>
        </div>

        <% if (vendedoresEmails && vendedoresEmails.length > 0) { %>
            <div class="checkout-section">
                <h2 class="section-title">Contato do Fornecedor</h2>
                <div class="email-contact">
                    <p><strong>E-mail para contato:</strong></p>
                    <% vendedoresEmails.forEach(email => { %>
                        <p><i class="fas fa-envelope"></i> <a href="mailto:<%= email %>"><%= email %></a></p>
                    <% }); %>
                </div>
            </div>
        <% } %>

        <button class="btn-confirmar" id="btn-confirmar" onclick="confirmarVenda()">
            CONFIRMAR PEDIDO
        </button>

    </div>
</div>
    <script>
        function confirmarVenda() {
            const btn = document.getElementById('btn-confirmar');
            btn.disabled = true;
            btn.textContent = 'Processando...';

            fetch('/finalizar-venda', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Pedido confirmado com sucesso!');
                    window.location.href = '/gestao-cadastro';
                } else {
                    alert(data.message || 'Erro ao confirmar pedido');
                    btn.disabled = false;
                    btn.textContent = 'CONFIRMAR PEDIDO';
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao processar pedido');
                btn.disabled = false;
                btn.textContent = 'CONFIRMAR PEDIDO';
            });
        }
    </script>
</body>
</html>

