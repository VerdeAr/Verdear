{
	"name": "verdear",
	"version": "1.0.0",
	"description": "Verdear",
	"type": "module",
	"main": "src/app.ts",
	"scripts": {
		"prepare": "husky",
		"check": "tsc --noEmit && biome check --error-on-warnings",
		"format": "biome check --write --unsafe",
		"start": "tsc --noEmit && bun run src/app.ts",
		"dev": "docker compose up banco -d && bunx bun prisma generate && bunx --bun prisma migrate dev && tsc --noEmit && bun --watch src/app.ts"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"bcrypt": "^6.0.0",
		"cors": "^2.8.5",
		"ejs": "^5.0.2",
		"express": "^5.2.1",
		"express-session": "^1.18.2",
		"handlebars": "^4.7.9",
		"pg": "^8.20.0",
		"prisma": "^7.8.0"
	},
	"author": "",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/VerdeAr/Verdear.git"
	},
	"homepage": "https://github.com/VerdeAr/Verdear#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@commitlint/cli": "^20.5.2",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/bcrypt": "^6.0.0",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.19.0",
		"@types/pg": "^8.20.0",
		"bun-types": "^1.3.13",
		"husky": "^9.1.7",
		"typescript": "^6.0.3"
	}
}
